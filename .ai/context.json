      "audited": true,
      "globalScope": "school",
      "relationships": {
        "belongsTo": ["schools"],
        "hasMany": ["equipment_assignments"]
      },
      "keyFields": ["employee_id", "last_name", "first_name", "position", "employment_type", "is_teaching"]
    },
    "equipment": {
      "model": "App\\Models\\Equipment",
      "table": "equipment",
      "resource": "App\\Filament\\Resources\\EquipmentResource",
      "softDeletes": true,
      "audited": true,
      "globalScope": "school",
      "hasQrCode": true,
      "relationships": {
        "belongsTo": ["schools"],
        "hasMany": ["equipment_assignments", "documents"],
        "hasOne": ["active_assignment"]
      },
      "keyFields": [
        "property_no", "old_property_no", "serial_no", "brand", "model",
        "item_type", "is_dcp", "dcp_package", "category", "condition",
        "functional_status", "accountability_status", "acquisition_cost",
        "acquisition_date", "mode_of_acquisition", "warranty_expiry"
      ],
      "importantRules": [
        "No employee_id FK on this table",
        "Accountability tracked via equipment_assignments only",
        "QR code auto-generated on creation by Observer"
      ]
    },
