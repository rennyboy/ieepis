      "softDeletes": true,
      "audited": false,
      "globalScope": "school",
      "relationships": {
        "belongsTo": ["schools", "equipment", "employees (reporter)", "users (technician)"]
      },
      "keyFields": [
        "ticket_number", "priority", "status", "description",
        "resolution_notes", "resolved_at"
      ],
      "importantRules": [
        "Ticket numbers auto-generated as TKT-YYYY-XXXX",
        "priority: Low | Medium | High | Critical",
        "status: Open | In-Progress | Pending | Resolved | Closed"
      ]
    },
    "internet_connections": {
      "model": "App\\Models\\InternetConnection",
