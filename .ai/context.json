{
  "version": "1.0",
  "generated": "2026-04-07",
  "project": "IEEPIS",
  "description": "ICT Equipment and Employee Profile Information System for DepEd Philippines",

  "modules": {
    "schools": {
      "model": "App\\Models\\School",
      "table": "schools",
      "resource": "App\\Filament\\Resources\\SchoolResource",
      "softDeletes": true,
