      "audited": false,
      "globalScope": "school",
      "relationships": {
        "belongsTo": ["equipment", "employees (accountable_officer)", "employees (end_user)"]
      },
      "keyFields": [
        "equipment_id", "accountable_officer_id", "end_user_id",
        "transaction_type", "document_reference", "is_active",
        "assigned_date", "receipt_date"
      ],
      "importantRules": [
        "Only one active assignment per equipment at a time",
        "transaction_type: Beginning Inventory | Issuance | Transfer | Return"
      ]
    },
    "documents": {
      "model": "App\\Models\\Document",
      "table": "documents",
