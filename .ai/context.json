        "contracted_download_speed", "contracted_upload_speed",
        "actual_download_speed", "actual_upload_speed", "monthly_cost"
      ]
    }
  },

  "globalPatterns": {
    "softDeleteModels": ["School", "Employee", "Equipment", "Document", "Ticket"],
    "auditedModels": ["School", "Employee", "Equipment"],
    "schoolScopedModels": ["Employee", "Equipment", "EquipmentAssignment", "Document", "Ticket", "InternetConnection"],
    "observerDriven": ["Equipment (QR code)", "Ticket (auto ticket number)"]
